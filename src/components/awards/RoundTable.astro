---
/**
 * RoundTable (Static Astro)
 * Full-width table showing all application round dates and statuses.
 * Highlights the current/active round row.
 * Rendered at build time — rebuilt every ~2 hours via CI.
 */
import { getRoundData, getRoundStatus, type ProcessedRound } from "./round";
import Icon from "@components/Icon.astro";

const { allRounds, currentRound, nextRound, devDateTime } = getRoundData();
const { round: displayRound } = getRoundStatus({
    currentRound,
    nextRound,
    devDateTime,
});

// ─── Helpers ────────────────────────────────────────────────────────────

function getStatusBadgeClass(round: ProcessedRound): string {
    if (round.isUpcoming)
        return "bg-indigo-500/80 text-white border border-indigo-400/50";
    if (round.isOpen)
        return "bg-emerald-500/80 text-white border border-emerald-400/50";
    if (round.phase === "closed")
        return "bg-slate-600/80 text-white border border-slate-500/50";
    if (round.isInAssessment)
        return "bg-amber-500/80 text-white border border-amber-400/50";
    if (round.isInInterview)
        return "bg-yellow-500/80 text-white border border-yellow-400/50";
    if (round.phase === "awaiting-results")
        return "bg-sky-500/80 text-white border border-sky-400/50";
    if (round.isInResults)
        return "bg-violet-500/80 text-white border border-violet-400/50";
    if (round.phase === "completed")
        return "bg-slate-600/80 text-white border border-slate-500/50";
    return "bg-slate-500/80 text-white border border-slate-400/50";
}

function getStatusLabel(round: ProcessedRound): string {
    if (round.isUpcoming) return "Coming soon";
    if (round.isOpen) return "Open now";
    if (round.phase === "closed") return "Closed";
    if (round.isInAssessment) return "Assessing";
    if (round.isInInterview) return "Panel";
    if (round.phase === "awaiting-results") return "Assessments complete";
    if (round.isInResults) return "Emailing results";
    if (round.phase === "completed") return "Complete";
    return round.phaseInfo?.shortLabel || "Unknown";
}

function getRowClass(round: ProcessedRound): string {
    if (displayRound && round.id === displayRound.id) {
        return "bg-violet-800/40 border-l-4 border-l-violet-400";
    }
    if (round.isOpen) return "bg-emerald-900/20";
    if (round.isUpcoming) return "bg-indigo-900/10";
    if (round.phase === "completed") return "opacity-60";
    return "";
}

/** Extract hour in 24h format from an ISO date string, e.g. "09" or "17" */
function formatHour(iso: string | null): string {
    if (!iso) return "";
    const h = new Date(iso).getHours();
    return h.toString().padStart(2, "0") + ":00";
}

const hasRounds = allRounds && allRounds.length > 0;
---

{
    hasRounds && (
        <div class="bg-violet-950 text-white rounded-2xl p-6 md:p-8">
            <h3 class="text-xl font-bold mb-6 text-violet-100 flex items-center gap-2">
                <Icon
                    name="calendar-days"
                    style="solid"
                    class="text-violet-300"
                />
                Application Rounds
            </h3>

            <div class="overflow-x-auto -mx-2">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-violet-700/50">
                            <th class="text-left py-3 px-2 font-semibold text-violet-300 text-xs uppercase tracking-wide">
                                Status
                            </th>
                            <th class="text-left py-3 px-2 font-semibold text-violet-300 text-xs uppercase tracking-wide">
                                Apply
                            </th>
                            <th class="text-left py-3 px-2 font-semibold text-violet-300 text-xs uppercase tracking-wide">
                                Capacity
                            </th>
                            <th class="text-left py-3 px-2 font-semibold text-violet-300 text-xs uppercase tracking-wide hidden md:table-cell">
                                Application review
                            </th>
                            <th class="text-left py-3 px-2 font-semibold text-violet-300 text-xs uppercase tracking-wide hidden md:table-cell">
                                Panel &amp; recommendation
                            </th>
                            <th class="text-left py-3 px-2 font-semibold text-violet-300 text-xs uppercase tracking-wide hidden md:table-cell">
                                Result
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {allRounds.map((round) => (
                            <tr
                                class={`border-b border-violet-800/30 ${getRowClass(round)}`}
                            >
                                <td class="py-3 px-2">
                                    <span
                                        class={`inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-medium ${getStatusBadgeClass(round)}`}
                                    >
                                        {getStatusLabel(round)}
                                    </span>
                                </td>
                                <td class="py-3 px-2">
                                    <span
                                        class={`font-medium ${round.id === displayRound?.id ? "text-white" : round.phase === "completed" ? "text-violet-400" : "text-violet-200"}`}
                                    >
                                        {round.dates.opensShort}{" "}
                                        <span class="text-xs opacity-70">
                                            {formatHour(round.opensDate)}
                                        </span>
                                    </span>
                                    <span
                                        class={`${round.phase === "completed" ? "text-violet-500" : "text-violet-300"}`}
                                    >
                                        {" "}
                                        – {round.dates.closesShort}{" "}
                                        <span class="text-xs opacity-70">
                                            {formatHour(round.closesDate)}
                                        </span>
                                    </span>
                                </td>
                                <td class="py-3 px-2">
                                    {round.hasCapacity ? (
                                        <span
                                            class={`text-xs font-medium ${round.capacityPercentage >= 80 ? "text-red-400" : round.capacityPercentage >= 60 ? "text-amber-400" : "text-emerald-400"}`}
                                        >
                                            {round.applicationCount}/
                                            {round.applicationLimit}{" "}
                                            <span class="opacity-70">
                                                ({round.capacityPercentage}%)
                                            </span>
                                        </span>
                                    ) : (
                                        <span class="text-xs text-violet-500">
                                            —
                                        </span>
                                    )}
                                </td>
                                <td
                                    class={`py-3 px-2 hidden md:table-cell ${round.phase === "completed" ? "text-violet-500" : "text-violet-300"}`}
                                >
                                    {round.dates.assessmentStartShort} –{" "}
                                    {round.dates.assessmentEndShort}
                                </td>
                                <td
                                    class={`py-3 px-2 hidden md:table-cell ${round.phase === "completed" ? "text-violet-500" : "text-violet-300"}`}
                                >
                                    {round.dates.interviewStartShort &&
                                    round.dates.interviewEndShort
                                        ? `${round.dates.interviewStartShort} – ${round.dates.interviewEndShort}`
                                        : "—"}
                                </td>
                                <td
                                    class={`py-3 px-2 hidden md:table-cell ${round.phase === "completed" ? "text-violet-500" : "text-violet-300"}`}
                                >
                                    {round.dates.resultsStartShort} –{" "}
                                    {round.dates.resultsEndShort}
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </div>
    )
}
