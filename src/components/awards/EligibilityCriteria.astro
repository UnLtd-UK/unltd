---
import Icon from "@components/Icon.astro";
import {
    awardCodes,
    awardKeys,
    allSectors,
    eligibilityData,
    renderCriterionValue,
    getAwardInfo,
    type AwardCode,
} from "@data/eligibilityCriteria";

const isAllSectors = (value: string[]) =>
    allSectors.size > 0 &&
    value.length >= allSectors.size &&
    [...allSectors].every((s) => value.includes(s));
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12">
        <h2
            class="text-3xl md:text-4xl font-bold text-violet-900 dark:text-violet-100 mb-4"
        >
            Full Eligibility Criteria
        </h2>
        <p
            class="text-lg text-violet-700 dark:text-violet-300 max-w-2xl mx-auto"
        >
            Want to check through the eligibility criteria before you begin?
            Here's a detailed breakdown of all eligibility requirements for each
            Award type.
        </p>
    </div>

    <!-- Eligibility Tables -->
    <div class="space-y-12 mb-16">
        {
            eligibilityData.map((category, categoryIdx) => (
                <div class="bg-white rounded-2xl border border-violet-200 overflow-hidden shadow-sm">
                    <div class="bg-violet-50 border-b border-violet-200 px-6 py-4 flex items-center gap-3">
                        {category.name === "Social entrepreneur" ? (
                            <Icon
                                name="user"
                                style="solid"
                                class="h-5 w-5 text-violet-600"
                            />
                        ) : (
                            <Icon
                                name="building"
                                style="solid"
                                class="h-5 w-5 text-violet-600"
                            />
                        )}
                        <h3 class="font-semibold text-foreground">
                            {category.name} requirements
                        </h3>
                    </div>
                    <div class="p-4 md:p-6">
                        <div class="overflow-x-auto -mx-4 sm:mx-0">
                            <table class="w-full min-w-200">
                                <thead>
                                    <tr class="border-b border-slate-200">
                                        <th class="text-left py-4 px-4 font-semibold text-slate-900 w-[40%]">
                                            Criteria
                                        </th>
                                        {awardKeys.map((code) => {
                                            const info = getAwardInfo(code);
                                            return (
                                                <th
                                                    data-award={code}
                                                    class="text-center py-4 px-2 font-medium text-slate-700 text-xs transition-colors duration-300"
                                                >
                                                    <span class="block text-xs font-semibold">
                                                        {info?.name}
                                                    </span>
                                                </th>
                                            );
                                        })}
                                    </tr>
                                </thead>
                                <tbody>
                                    {category.criteria.map(
                                        (criterion, criterionIdx) => {
                                            const isSectorRow =
                                                criterion.slug ===
                                                "sector_classification";
                                            return (
                                                <tr
                                                    class:list={[
                                                        "border-b border-slate-100",
                                                        criterionIdx % 2 === 0
                                                            ? "bg-white"
                                                            : "bg-slate-50/50",
                                                    ]}
                                                >
                                                    <td class="py-4 px-4 text-sm text-slate-700">
                                                        {criterion.name}
                                                    </td>
                                                    {awardKeys.map((code) => {
                                                        const value =
                                                            criterion.awards[
                                                                code
                                                            ];
                                                        const rendered =
                                                            renderCriterionValue(
                                                                value,
                                                            );
                                                        return (
                                                            <td
                                                                data-award={
                                                                    code
                                                                }
                                                                class="py-4 px-2 text-center transition-colors duration-300"
                                                            >
                                                                {isSectorRow &&
                                                                Array.isArray(
                                                                    value,
                                                                ) ? (
                                                                    <div class="text-left">
                                                                        {isAllSectors(
                                                                            value,
                                                                        ) ? (
                                                                            <span class="inline-flex items-center gap-1.5 text-emerald-600">
                                                                                <Icon
                                                                                    name="check"
                                                                                    style="solid"
                                                                                    class="h-4 w-4"
                                                                                />
                                                                                <span class="text-xs font-medium">
                                                                                    Any
                                                                                    social
                                                                                    issue
                                                                                </span>
                                                                            </span>
                                                                        ) : (
                                                                            <div class="flex flex-wrap gap-1.5">
                                                                                {value.map(
                                                                                    (
                                                                                        sector,
                                                                                    ) => (
                                                                                        <span class="inline-block px-2 py-0.5 bg-slate-100 text-slate-600 text-xs rounded-md">
                                                                                            {
                                                                                                sector
                                                                                            }
                                                                                        </span>
                                                                                    ),
                                                                                )}
                                                                            </div>
                                                                        )}
                                                                    </div>
                                                                ) : rendered.type ===
                                                                  "null" ? (
                                                                    <span class="inline-flex items-center gap-1.5 text-slate-400">
                                                                        <Icon
                                                                            name="minus"
                                                                            style="solid"
                                                                            class="h-4 w-4"
                                                                        />
                                                                        <span class="text-xs">
                                                                            N/A
                                                                        </span>
                                                                    </span>
                                                                ) : rendered.type ===
                                                                  "true" ? (
                                                                    <span class="inline-flex items-center gap-1.5 text-emerald-600">
                                                                        <Icon
                                                                            name="check"
                                                                            style="solid"
                                                                            class="h-4 w-4"
                                                                        />
                                                                        <span class="text-xs font-medium">
                                                                            Yes
                                                                        </span>
                                                                    </span>
                                                                ) : rendered.type ===
                                                                  "false" ? (
                                                                    <span class="inline-flex items-center gap-1.5 text-red-500">
                                                                        <Icon
                                                                            name="xmark"
                                                                            style="solid"
                                                                            class="h-4 w-4"
                                                                        />
                                                                        <span class="text-xs font-medium">
                                                                            No
                                                                        </span>
                                                                    </span>
                                                                ) : rendered.type ===
                                                                  "array" ? (
                                                                    <div class="text-xs text-slate-600">
                                                                        <span class="font-medium text-emerald-600">
                                                                            {
                                                                                rendered.count
                                                                            }{" "}
                                                                            items
                                                                        </span>
                                                                    </div>
                                                                ) : (
                                                                    <span class="text-xs text-slate-700 font-medium">
                                                                        {
                                                                            rendered.text
                                                                        }
                                                                    </span>
                                                                )}
                                                            </td>
                                                        );
                                                    })}
                                                </tr>
                                            );
                                        },
                                    )}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>

    <style>
        [x-cloak] {
            display: none !important;
        }

        /* Highlighted column styles */
        th[data-award].highlighted,
        td[data-award].highlighted {
            background-color: rgb(139 92 246 / 0.15) !important;
            box-shadow: inset 0 0 0 2px rgb(139 92 246 / 0.3);
        }

        th[data-award].highlighted {
            background-color: rgb(139 92 246 / 0.25) !important;
        }
    </style>

    <script>
        function highlightColumn() {
            const hash = window.location.hash.slice(1);

            // Remove existing highlights
            document
                .querySelectorAll("[data-award].highlighted")
                .forEach((el) => {
                    el.classList.remove("highlighted");
                });

            if (hash) {
                // Add highlight to matching columns
                document
                    .querySelectorAll(`[data-award="${hash}"]`)
                    .forEach((el) => {
                        el.classList.add("highlighted");
                    });

                // Scroll to the eligibility section
                const firstHighlighted = document.querySelector(
                    `[data-award="${hash}"]`,
                );
                if (firstHighlighted) {
                    setTimeout(() => {
                        firstHighlighted.scrollIntoView({
                            behavior: "smooth",
                            block: "center",
                        });
                    }, 100);
                }
            }
        }

        // Run on page load and hash change
        highlightColumn();
        window.addEventListener("hashchange", highlightColumn);
    </script>
</div>
