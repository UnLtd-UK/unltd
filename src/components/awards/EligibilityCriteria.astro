---
import Icon from "@components/Icon.astro";
import {
    awardCodes,
    awardKeys,
    eligibilityData,
    renderCriterionValue,
    getAwardInfo,
    type AwardCode,
} from "@data/eligibilityCriteria";
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12">
        <h2
            class="text-3xl md:text-4xl font-bold text-violet-900 dark:text-violet-100 mb-4"
        >
            Full Eligibility Criteria
        </h2>
        <p
            class="text-lg text-violet-700 dark:text-violet-300 max-w-2xl mx-auto"
        >
            Want to check through the eligibility criteria before you begin?
            Here's a detailed breakdown of all eligibility requirements for each
            Award type.
        </p>
    </div>

    <!-- Eligibility Tables -->
    <div class="space-y-12 mb-16">
        {
            eligibilityData.map((category, categoryIdx) => (
                <div class="bg-white rounded-2xl border border-violet-200 overflow-hidden shadow-sm">
                    <div class="bg-violet-50 border-b border-violet-200 px-6 py-4 flex items-center gap-3">
                        {category.name === "Social entrepreneur" ? (
                            <Icon
                                name="user"
                                style="solid"
                                class="h-5 w-5 text-violet-600"
                            />
                        ) : (
                            <Icon
                                name="building"
                                style="solid"
                                class="h-5 w-5 text-violet-600"
                            />
                        )}
                        <h3 class="font-semibold text-foreground">
                            {category.name} requirements
                        </h3>
                    </div>
                    <div class="p-4 md:p-6">
                        <div class="overflow-x-auto -mx-4 sm:mx-0">
                            <table class="w-full min-w-200">
                                <thead>
                                    <tr class="border-b border-slate-200">
                                        <th class="text-left py-4 px-4 font-semibold text-slate-900 w-[40%]">
                                            Criteria
                                        </th>
                                        {awardKeys.map((code) => {
                                            const info = getAwardInfo(code);
                                            return (
                                                <th
                                                    data-award={code}
                                                    class="text-center py-4 px-2 font-medium text-slate-700 text-xs transition-colors duration-300"
                                                >
                                                    <span class="block text-xs font-semibold">
                                                        {info?.name}
                                                    </span>
                                                </th>
                                            );
                                        })}
                                    </tr>
                                </thead>
                                <tbody>
                                    {category.criteria.map(
                                        (criterion, criterionIdx) => {
                                            const isSectorRow =
                                                criterion.slug ===
                                                "sector_classification";
                                            return (
                                                <tr
                                                    class:list={[
                                                        "border-b border-slate-100",
                                                        criterionIdx % 2 === 0
                                                            ? "bg-white"
                                                            : "bg-slate-50/50",
                                                    ]}
                                                >
                                                    <td class="py-4 px-4 text-sm text-slate-700">
                                                        {criterion.name}
                                                    </td>
                                                    {awardKeys.map((code) => {
                                                        const value =
                                                            criterion.awards[
                                                                code
                                                            ];
                                                        const rendered =
                                                            renderCriterionValue(
                                                                value,
                                                            );
                                                        return (
                                                            <td
                                                                data-award={
                                                                    code
                                                                }
                                                                class="py-4 px-2 text-center transition-colors duration-300"
                                                            >
                                                                {isSectorRow &&
                                                                Array.isArray(
                                                                    value,
                                                                ) ? (
                                                                    <div class="text-left">
                                                                        {value.length <=
                                                                        4 ? (
                                                                            <div class="flex flex-wrap gap-1.5">
                                                                                {value.map(
                                                                                    (
                                                                                        sector,
                                                                                    ) => (
                                                                                        <span class="inline-block px-2 py-0.5 bg-slate-100 text-slate-600 text-xs rounded-md">
                                                                                            {
                                                                                                sector
                                                                                            }
                                                                                        </span>
                                                                                    ),
                                                                                )}
                                                                            </div>
                                                                        ) : (
                                                                            <button
                                                                                type="button"
                                                                                class="sector-dialog-trigger text-xs text-teal-600 hover:text-teal-700 font-medium flex items-center gap-1 mx-auto cursor-pointer"
                                                                                data-sectors={JSON.stringify(
                                                                                    value,
                                                                                )}
                                                                                data-award-name={
                                                                                    getAwardInfo(
                                                                                        code,
                                                                                    )
                                                                                        ?.name ??
                                                                                    code
                                                                                }
                                                                            >
                                                                                <span>
                                                                                    See
                                                                                    all{" "}
                                                                                    {
                                                                                        value.length
                                                                                    }{" "}
                                                                                    sectors
                                                                                </span>
                                                                                <Icon
                                                                                    name="arrow-up-right-from-square"
                                                                                    style="solid"
                                                                                    class="text-[10px]"
                                                                                />
                                                                            </button>
                                                                        )}
                                                                    </div>
                                                                ) : rendered.type ===
                                                                  "null" ? (
                                                                    <span class="inline-flex items-center gap-1.5 text-slate-400">
                                                                        <Icon
                                                                            name="minus"
                                                                            style="solid"
                                                                            class="h-4 w-4"
                                                                        />
                                                                        <span class="text-xs">
                                                                            N/A
                                                                        </span>
                                                                    </span>
                                                                ) : rendered.type ===
                                                                  "true" ? (
                                                                    <span class="inline-flex items-center gap-1.5 text-emerald-600">
                                                                        <Icon
                                                                            name="check"
                                                                            style="solid"
                                                                            class="h-4 w-4"
                                                                        />
                                                                        <span class="text-xs font-medium">
                                                                            Yes
                                                                        </span>
                                                                    </span>
                                                                ) : rendered.type ===
                                                                  "false" ? (
                                                                    <span class="inline-flex items-center gap-1.5 text-red-500">
                                                                        <Icon
                                                                            name="xmark"
                                                                            style="solid"
                                                                            class="h-4 w-4"
                                                                        />
                                                                        <span class="text-xs font-medium">
                                                                            No
                                                                        </span>
                                                                    </span>
                                                                ) : rendered.type ===
                                                                  "array" ? (
                                                                    <div class="text-xs text-slate-600">
                                                                        <span class="font-medium text-emerald-600">
                                                                            {
                                                                                rendered.count
                                                                            }{" "}
                                                                            items
                                                                        </span>
                                                                    </div>
                                                                ) : (
                                                                    <span class="text-xs text-slate-700 font-medium">
                                                                        {
                                                                            rendered.text
                                                                        }
                                                                    </span>
                                                                )}
                                                            </td>
                                                        );
                                                    })}
                                                </tr>
                                            );
                                        },
                                    )}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>

    <!-- Legend -->
    <div class="bg-white rounded-xl border border-violet-200 p-4">
        <h4 class="text-sm font-medium text-foreground mb-3">
            Understanding the table
        </h4>
        <div class="flex flex-wrap gap-6 text-sm">
            <div class="flex items-center gap-2">
                <Icon
                    name="check"
                    style="solid"
                    class="h-4 w-4 text-emerald-600"
                />
                <span class="text-muted-foreground"
                    >Required / Must answer Yes</span
                >
            </div>
            <div class="flex items-center gap-2">
                <Icon name="xmark" style="solid" class="h-4 w-4 text-red-500" />
                <span class="text-muted-foreground">Must answer No</span>
            </div>
            <div class="flex items-center gap-2">
                <Icon
                    name="minus"
                    style="solid"
                    class="h-4 w-4 text-violet-400"
                />
                <span class="text-muted-foreground"
                    >Not applicable for this award</span
                >
            </div>
            <div class="flex items-center gap-2">
                <span
                    class="px-2 py-0.5 bg-violet-100 text-violet-700 text-xs rounded"
                    >Starting Up</span
                >
                <span class="text-muted-foreground">Early-stage ventures</span>
            </div>
            <div class="flex items-center gap-2">
                <span
                    class="px-2 py-0.5 bg-violet-900 text-white text-xs rounded"
                    >Scaling Up</span
                >
                <span class="text-muted-foreground">Established ventures</span>
            </div>
        </div>
    </div>
</div>

<!-- Sector dialog (Tailwind Plus style) -->
<dialog
    id="sector-dialog"
    aria-labelledby="sector-dialog-title"
    class="fixed inset-0 size-auto max-h-none max-w-none overflow-y-auto bg-transparent backdrop:bg-transparent z-50"
>
    <div
        class="fixed inset-0 bg-gray-500/75 transition-opacity dark:bg-gray-900/50"
    >
    </div>
    <div
        tabindex="0"
        class="flex min-h-full items-end justify-center p-4 text-center focus:outline-none sm:items-center sm:p-0"
    >
        <div
            class="relative transform overflow-hidden rounded-lg bg-white px-4 pt-5 pb-4 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-sm sm:p-6 dark:bg-gray-800 dark:outline dark:-outline-offset-1 dark:outline-white/10"
        >
            <div>
                <div
                    class="mx-auto flex size-12 items-center justify-center rounded-full bg-green-100 dark:bg-green-500/10"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        aria-hidden="true"
                        class="size-6 text-green-600 dark:text-green-400"
                    >
                        <path
                            d="m4.5 12.75 6 6 9-13.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </div>
                <div class="mt-3 text-center sm:mt-5">
                    <h3
                        id="sector-dialog-title"
                        class="text-base font-semibold text-gray-900 dark:text-white"
                    >
                    </h3>
                    <div class="mt-2">
                        <div
                            id="sector-dialog-list"
                            class="flex flex-wrap gap-2 justify-center max-h-48 overflow-y-auto"
                        >
                        </div>
                    </div>
                </div>
            </div>
            <div class="mt-5 sm:mt-6">
                <button
                    type="button"
                    id="sector-dialog-done"
                    class="inline-flex w-full justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:shadow-none dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500"
                    >Close</button
                >
            </div>
            <button
                id="sector-dialog-close"
                class="absolute top-3 right-3 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-white"
                aria-label="Close dialog"
            >
                <svg
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>
</dialog>

<style>
    [x-cloak] {
        display: none !important;
    }

    /* Highlighted column styles */
    th[data-award].highlighted,
    td[data-award].highlighted {
        background-color: rgb(139 92 246 / 0.15) !important;
        box-shadow: inset 0 0 0 2px rgb(139 92 246 / 0.3);
    }

    th[data-award].highlighted {
        background-color: rgb(139 92 246 / 0.25) !important;
    }
</style>

<script>
    function highlightColumn() {
        const hash = window.location.hash.slice(1);

        // Remove existing highlights
        document.querySelectorAll("[data-award].highlighted").forEach((el) => {
            el.classList.remove("highlighted");
        });

        if (hash) {
            // Add highlight to matching columns
            document
                .querySelectorAll(`[data-award="${hash}"]`)
                .forEach((el) => {
                    el.classList.add("highlighted");
                });

            // Scroll to the eligibility section
            const firstHighlighted = document.querySelector(
                `[data-award="${hash}"]`,
            );
            if (firstHighlighted) {
                setTimeout(() => {
                    firstHighlighted.scrollIntoView({
                        behavior: "smooth",
                        block: "center",
                    });
                }, 100);
            }
        }
    }

    // Run on page load and hash change
    highlightColumn();
    window.addEventListener("hashchange", highlightColumn);

    // Sector dialog
    const dialog = document.getElementById(
        "sector-dialog",
    ) as HTMLDialogElement;
    const dialogTitle = document.getElementById("sector-dialog-title")!;
    const dialogList = document.getElementById("sector-dialog-list")!;
    const dialogClose = document.getElementById("sector-dialog-close")!;
    const dialogDone = document.getElementById("sector-dialog-done")!;

    function openSectorDialog(sectors, awardName) {
        dialogTitle.textContent = `${awardName} — Eligible Sectors`;
        // Sort sectors alphabetically, case-insensitive
        const sorted = [...sectors].sort((a, b) =>
            a.localeCompare(b, undefined, { sensitivity: "base" }),
        );
        dialogList.innerHTML = sorted
            .map(
                (s) =>
                    `<span class="inline-block px-2.5 py-1 bg-slate-100 text-slate-700 text-sm rounded-md">${s}</span>`,
            )
            .join("");
        dialog.showModal();
        setTimeout(() => dialogDone.focus(), 100);
    }

    dialogClose.addEventListener("click", () => dialog.close());
    dialogDone.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
    });

    document.querySelectorAll(".sector-dialog-trigger").forEach((btn) => {
        btn.addEventListener("click", () => {
            const sectors = JSON.parse(
                btn.getAttribute("data-sectors") || "[]",
            );
            const awardName = btn.getAttribute("data-award-name") || "";
            openSectorDialog(sectors, awardName);
        });
    });
</script>
